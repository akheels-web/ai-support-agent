[Unit]
Description=Apply National Finance Branding to Zammad
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/opt/ai-support-agent/zammad-branding/apply_zammad_branding.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user

systemctl daemon-reload
systemctl enable zammad-branding

