/*
 * ============================================================
 *  National Finance Oman — Zammad Custom Branding CSS
 *  File: /opt/zammad/app/assets/stylesheets/custom/custom.css
 *  After editing: run  zammad run rails assets:precompile
 *                 then  systemctl restart zammad
 * ============================================================
 *
 *  Brand Palette (extracted from National Finance Oman logo):
 *    Navy Blue  #1B2F6B  — primary brand / header / sidebar
 *    Brand Red  #C8102E  — accent / CTAs / tags
 *    Mid Blue   #2B4A9F  — hover states / secondary elements
 *    Light Blue #E8EDF8  — background tints
 *    Warm White #F7F8FC  — page background
 *    Dark Grey  #2D2D2D  — body text
 *    Mid Grey   #6B7280  — secondary text / meta
 *    Border     #D1D9F0  — subtle borders
 *
 *  Priority system colours:
 *    Low    #3B82F6 (blue)
 *    Normal #10B981 (green)
 *    High   #F59E0B (amber)
 *    Urgent #C8102E (brand red)
 *
 *  State colours:
 *    New      #1B2F6B (navy)
 *    Open     #C8102E (red)
 *    Pending  #F59E0B (amber)
 *    Closed   #6B7280 (grey)
 * ============================================================
 */


/* ─── ROOT VARIABLES ──────────────────────────────────────── */
:root {
  --nf-navy:        #1B2F6B;
  --nf-navy-dark:   #132250;
  --nf-navy-mid:    #2B4A9F;
  --nf-navy-light:  #E8EDF8;
  --nf-red:         #C8102E;
  --nf-red-dark:    #A50E26;
  --nf-white:       #FFFFFF;
  --nf-bg:          #F7F8FC;
  --nf-text:        #2D2D2D;
  --nf-text-meta:   #6B7280;
  --nf-border:      #D1D9F0;
  --nf-shadow:      0 2px 12px rgba(27,47,107,0.10);
}


/* ══════════════════════════════════════════════════════════ */
/*  1. LOGIN PAGE                                             */
/* ══════════════════════════════════════════════════════════ */

/* Page background */
.login {
  background: linear-gradient(160deg, var(--nf-navy) 0%, var(--nf-navy-mid) 55%, #3A5FBF 100%) !important;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Login card */
.login .login-form,
.login form,
.login .card {
  background: var(--nf-white) !important;
  border-radius: 12px !important;
  box-shadow: 0 24px 60px rgba(0,0,0,0.25) !important;
  border: none !important;
  padding: 40px !important;
}

/* Logo area on login — Zammad loads this via the branding logo upload.
   The selectors below add spacing and centering around it. */
.login .logo,
.login-logo,
#logo {
  display: block;
  margin: 0 auto 28px auto;
  max-width: 200px;
  max-height: 70px;
  object-fit: contain;
}

/* Field labels */
.login label {
  color: var(--nf-navy) !important;
  font-weight: 600 !important;
  font-size: 12px !important;
  letter-spacing: 0.6px !important;
  text-transform: uppercase !important;
}

/* Input fields */
.login input[type="text"],
.login input[type="email"],
.login input[type="password"] {
  border: 1.5px solid var(--nf-border) !important;
  border-radius: 7px !important;
  padding: 10px 14px !important;
  font-size: 14px !important;
  color: var(--nf-text) !important;
  background: var(--nf-bg) !important;
  transition: border-color 0.2s ease;
}

.login input:focus {
  border-color: var(--nf-navy-mid) !important;
  outline: none !important;
  box-shadow: 0 0 0 3px rgba(43,74,159,0.15) !important;
  background: var(--nf-white) !important;
}

/* Sign In button */
.login [type="submit"],
.login .btn-primary,
.login button[type="submit"] {
  background: var(--nf-navy) !important;
  border: none !important;
  border-radius: 7px !important;
  color: var(--nf-white) !important;
  font-weight: 700 !important;
  font-size: 14px !important;
  letter-spacing: 0.5px !important;
  padding: 12px !important;
  width: 100% !important;
  transition: background 0.2s ease !important;
}

.login [type="submit"]:hover,
.login button[type="submit"]:hover {
  background: var(--nf-navy-mid) !important;
}

/* Forgot password link */
.login a {
  color: var(--nf-red) !important;
  font-weight: 500 !important;
}

.login a:hover {
  color: var(--nf-red-dark) !important;
  text-decoration: underline !important;
}

/* ── "Powered by Zammad" footer → replace with NF branding ─ */
/* Hide the Zammad powered-by logo */
.login .powered,
.login .poweredBy,
.login [class*="powered"],
.login footer img[src*="zammad"],
.login .zammad-logo {
  display: none !important;
}

/* Inject a custom NF IT Support footer line */
.login::after {
  content: "© National Finance Oman · IT Support Portal";
  display: block;
  position: fixed;
  bottom: 20px;
  left: 0;
  right: 0;
  text-align: center;
  color: rgba(255,255,255,0.55);
  font-size: 12px;
  font-family: inherit;
  pointer-events: none;
}

/* Register link */
.login .register a,
.login .register {
  color: rgba(255,255,255,0.75) !important;
  font-size: 12px;
}


/* ══════════════════════════════════════════════════════════ */
/*  2. TOP NAVIGATION BAR                                     */
/* ══════════════════════════════════════════════════════════ */

/* Main top bar */
#navigation,
.navigation,
nav.navigation {
  background: var(--nf-navy) !important;
  border-bottom: 3px solid var(--nf-red) !important;
  box-shadow: 0 2px 12px rgba(0,0,0,0.2) !important;
}

/* App name / branding text in top bar */
#navigation .brand,
.navigation .brand,
#brand {
  color: var(--nf-white) !important;
  font-weight: 700 !important;
  font-size: 15px !important;
  letter-spacing: 0.3px !important;
}

/* Hide Zammad logo in top-left — the org logo upload replaces this.
   If Zammad still renders its own logo asset, hide it: */
#navigation img[src*="zammad"],
.navigation img[src*="zammad"],
#navigation .logo img[alt*="Zammad"],
.zammad-logo-nav {
  opacity: 0 !important;
  width: 0 !important;
  overflow: hidden !important;
}

/* Nav icons and links */
#navigation a,
.navigation a {
  color: rgba(255,255,255,0.80) !important;
  transition: color 0.15s ease !important;
}

#navigation a:hover,
.navigation a:hover,
#navigation a.active,
.navigation a.active {
  color: var(--nf-white) !important;
}

/* Active nav underline */
#navigation .active,
.navigation .active {
  border-bottom: 3px solid var(--nf-red) !important;
}

/* Search bar in nav */
#navigation .search input,
.navigation .search input,
#global-search {
  background: rgba(255,255,255,0.12) !important;
  border: 1px solid rgba(255,255,255,0.2) !important;
  border-radius: 20px !important;
  color: var(--nf-white) !important;
  padding: 6px 14px !important;
}

#navigation .search input::placeholder,
#global-search::placeholder {
  color: rgba(255,255,255,0.55) !important;
}

/* User avatar bubble */
#navigation .user,
.navigation .user {
  background: var(--nf-red) !important;
  border-radius: 50% !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  3. LEFT SIDEBAR                                           */
/* ══════════════════════════════════════════════════════════ */

#app-content aside,
.sidebar-left,
.column.left {
  background: var(--nf-navy-light) !important;
  border-right: 1px solid var(--nf-border) !important;
}

.sidebar-left a,
.column.left a {
  color: var(--nf-navy) !important;
  border-radius: 6px !important;
  transition: background 0.15s ease, color 0.15s ease !important;
}

.sidebar-left a:hover,
.column.left a:hover {
  background: rgba(27,47,107,0.08) !important;
  color: var(--nf-navy-dark) !important;
}

.sidebar-left a.active,
.column.left a.active,
.sidebar-left .is-active {
  background: var(--nf-navy) !important;
  color: var(--nf-white) !important;
  font-weight: 600 !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  4. DASHBOARD                                              */
/* ══════════════════════════════════════════════════════════ */

/* Page background */
body,
#app,
.main-content,
.dashboard {
  background: var(--nf-bg) !important;
}

/* Dashboard stat cards */
.dashboard .stats,
.stat-widget,
.widget {
  background: var(--nf-white) !important;
  border: 1px solid var(--nf-border) !important;
  border-radius: 10px !important;
  box-shadow: var(--nf-shadow) !important;
  padding: 20px !important;
}

.stat-widget h2,
.widget h2,
.stat-widget .title,
.widget .title {
  color: var(--nf-navy) !important;
  font-weight: 700 !important;
  font-size: 13px !important;
  text-transform: uppercase !important;
  letter-spacing: 0.5px !important;
  border-bottom: 2px solid var(--nf-red) !important;
  padding-bottom: 8px !important;
  margin-bottom: 14px !important;
}

/* Stat numbers */
.stat-widget .count,
.widget .count,
.stat-count {
  color: var(--nf-navy) !important;
  font-size: 36px !important;
  font-weight: 800 !important;
}

/* Widget accent underline */
.stat-widget::before,
.widget::before {
  content: '';
  display: block;
  height: 4px;
  background: linear-gradient(90deg, var(--nf-navy) 0%, var(--nf-red) 100%);
  border-radius: 10px 10px 0 0;
  position: absolute;
  top: 0; left: 0; right: 0;
}

.stat-widget,
.widget {
  position: relative;
  overflow: hidden;
}


/* ══════════════════════════════════════════════════════════ */
/*  5. TICKET LIST / OVERVIEWS                                */
/* ══════════════════════════════════════════════════════════ */

/* Table / ticket list container */
.ticket-list,
.overview-table,
.js-tableBody {
  background: var(--nf-white) !important;
  border-radius: 10px !important;
  border: 1px solid var(--nf-border) !important;
  overflow: hidden;
  box-shadow: var(--nf-shadow) !important;
}

/* Table header */
.ticket-list thead th,
.overview-table thead th,
.js-tableHead th {
  background: var(--nf-navy) !important;
  color: var(--nf-white) !important;
  font-weight: 600 !important;
  font-size: 12px !important;
  letter-spacing: 0.5px !important;
  text-transform: uppercase !important;
  padding: 12px 16px !important;
  border: none !important;
}

/* Ticket rows */
.ticket-list tbody tr,
.overview-table tbody tr,
.js-tableBody tr {
  border-bottom: 1px solid var(--nf-border) !important;
  transition: background 0.12s ease !important;
}

.ticket-list tbody tr:hover,
.overview-table tbody tr:hover,
.js-tableBody tr:hover {
  background: var(--nf-navy-light) !important;
}

.ticket-list td,
.overview-table td,
.js-tableBody td {
  color: var(--nf-text) !important;
  font-size: 13px !important;
  padding: 11px 16px !important;
  vertical-align: middle !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  6. PRIORITY BADGES                                        */
/* ══════════════════════════════════════════════════════════ */

/* Base badge style */
.ticket-priority,
[class*="priority"],
.badge-priority {
  display: inline-flex !important;
  align-items: center !important;
  gap: 5px !important;
  padding: 3px 10px !important;
  border-radius: 20px !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  letter-spacing: 0.4px !important;
  text-transform: uppercase !important;
}

/* 1 Low */
[class*="priority-1"],
.priority-low,
[data-priority="1 low"] {
  background: #DBEAFE !important;
  color: #1D4ED8 !important;
}

/* 2 Normal */
[class*="priority-2"],
.priority-normal,
[data-priority="2 normal"] {
  background: #D1FAE5 !important;
  color: #065F46 !important;
}

/* 3 High */
[class*="priority-3"],
.priority-high,
[data-priority="3 high"] {
  background: #FEF3C7 !important;
  color: #92400E !important;
}

/* Urgent (if exists) */
[class*="priority-urgent"],
.priority-urgent {
  background: #FEE2E2 !important;
  color: var(--nf-red-dark) !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  7. STATE / STATUS BADGES                                  */
/* ══════════════════════════════════════════════════════════ */

.ticket-state,
[class*="state"],
.badge-state {
  display: inline-flex !important;
  align-items: center !important;
  padding: 3px 10px !important;
  border-radius: 20px !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  letter-spacing: 0.4px !important;
  text-transform: uppercase !important;
}

.state--new,
[data-state="new"],
.is-new { background: #E8EDF8 !important; color: var(--nf-navy) !important; }

.state--open,
[data-state="open"],
.is-open { background: #FEE2E2 !important; color: var(--nf-red) !important; }

.state--pending,
[data-state*="pending"],
.is-pending { background: #FEF3C7 !important; color: #92400E !important; }

.state--closed,
[data-state="closed"],
.is-closed { background: #F3F4F6 !important; color: #6B7280 !important; }

.state--merged,
[data-state="merged"] { background: #EDE9FE !important; color: #5B21B6 !important; }


/* ══════════════════════════════════════════════════════════ */
/*  8. TICKET DETAIL VIEW                                     */
/* ══════════════════════════════════════════════════════════ */

/* Ticket header */
.ticket-title h1,
.ticket-zoom-title,
h1.ticket-title {
  color: var(--nf-navy) !important;
  font-weight: 800 !important;
  font-size: 22px !important;
}

/* Article / note bubbles */
.ticket-article,
.article,
.ticket-zoom-article {
  border-radius: 10px !important;
  border: 1px solid var(--nf-border) !important;
  margin-bottom: 16px !important;
  box-shadow: 0 1px 4px rgba(27,47,107,0.06) !important;
}

/* Agent note header */
.ticket-article .header,
.article .header {
  background: var(--nf-navy-light) !important;
  border-bottom: 1px solid var(--nf-border) !important;
  border-radius: 10px 10px 0 0 !important;
  padding: 10px 16px !important;
}

/* Right sidebar (ticket meta) */
.ticket-sidebar,
.sidebar-right {
  background: var(--nf-white) !important;
  border-left: 1px solid var(--nf-border) !important;
}

.ticket-sidebar h3,
.sidebar-right h3,
.sidebar-right .sidebar-title {
  color: var(--nf-navy) !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.6px !important;
  margin-bottom: 6px !important;
}

/* Ticket number label */
.ticket-number {
  color: var(--nf-red) !important;
  font-weight: 700 !important;
  font-size: 13px !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  9. BUTTONS                                                */
/* ══════════════════════════════════════════════════════════ */

.btn.btn-primary,
button.btn-primary,
.js-submit.btn-primary {
  background: var(--nf-navy) !important;
  border: none !important;
  border-radius: 7px !important;
  color: var(--nf-white) !important;
  font-weight: 700 !important;
  transition: background 0.2s ease !important;
}

.btn.btn-primary:hover,
button.btn-primary:hover {
  background: var(--nf-navy-mid) !important;
}

.btn.btn-danger,
button.btn-danger {
  background: var(--nf-red) !important;
  border: none !important;
  border-radius: 7px !important;
  color: var(--nf-white) !important;
  font-weight: 700 !important;
}

.btn.btn-danger:hover {
  background: var(--nf-red-dark) !important;
}

.btn.btn-secondary,
button.btn-secondary,
.btn.btn-default {
  background: var(--nf-white) !important;
  border: 1.5px solid var(--nf-border) !important;
  border-radius: 7px !important;
  color: var(--nf-navy) !important;
  font-weight: 600 !important;
}

.btn.btn-secondary:hover,
.btn.btn-default:hover {
  background: var(--nf-navy-light) !important;
  border-color: var(--nf-navy-mid) !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  10. FORMS & INPUTS (GENERAL)                              */
/* ══════════════════════════════════════════════════════════ */

input[type="text"],
input[type="email"],
input[type="search"],
textarea,
select {
  border: 1.5px solid var(--nf-border) !important;
  border-radius: 7px !important;
  color: var(--nf-text) !important;
  background: var(--nf-white) !important;
  font-size: 13px !important;
}

input:focus,
textarea:focus,
select:focus {
  border-color: var(--nf-navy-mid) !important;
  box-shadow: 0 0 0 3px rgba(43,74,159,0.12) !important;
  outline: none !important;
}

label {
  color: var(--nf-navy) !important;
  font-weight: 600 !important;
  font-size: 12px !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  11. MODAL DIALOGS                                         */
/* ══════════════════════════════════════════════════════════ */

.modal-dialog,
.dialog,
.modal {
  border-radius: 12px !important;
  border: none !important;
  box-shadow: 0 20px 60px rgba(0,0,0,0.25) !important;
}

.modal-header,
.dialog-header {
  background: var(--nf-navy) !important;
  color: var(--nf-white) !important;
  border-radius: 12px 12px 0 0 !important;
  padding: 16px 24px !important;
}

.modal-header h1,
.modal-header h2,
.modal-header h3,
.dialog-header h1,
.dialog-header h2 {
  color: var(--nf-white) !important;
  font-size: 16px !important;
  font-weight: 700 !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  12. NOTIFICATIONS / ALERTS                                */
/* ══════════════════════════════════════════════════════════ */

.alert-success,
.notice.success {
  background: #D1FAE5 !important;
  border-left: 4px solid #10B981 !important;
  color: #065F46 !important;
  border-radius: 7px !important;
}

.alert-warning,
.notice.warning {
  background: #FEF3C7 !important;
  border-left: 4px solid #F59E0B !important;
  color: #92400E !important;
  border-radius: 7px !important;
}

.alert-danger,
.alert-error,
.notice.error {
  background: #FEE2E2 !important;
  border-left: 4px solid var(--nf-red) !important;
  color: var(--nf-red-dark) !important;
  border-radius: 7px !important;
}

.alert-info,
.notice.info {
  background: var(--nf-navy-light) !important;
  border-left: 4px solid var(--nf-navy) !important;
  color: var(--nf-navy-dark) !important;
  border-radius: 7px !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  13. TAG PILLS                                             */
/* ══════════════════════════════════════════════════════════ */

.tag,
.badge-tag {
  background: var(--nf-navy-light) !important;
  color: var(--nf-navy) !important;
  border-radius: 12px !important;
  font-size: 11px !important;
  font-weight: 600 !important;
  padding: 2px 8px !important;
  border: 1px solid var(--nf-border) !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  14. SCROLLBARS (webkit)                                   */
/* ══════════════════════════════════════════════════════════ */

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--nf-bg); }
::-webkit-scrollbar-thumb {
  background: var(--nf-border);
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover { background: var(--nf-navy-mid); }


/* ══════════════════════════════════════════════════════════ */
/*  15. HIDE ALL REMAINING ZAMMAD BRANDING                    */
/* ══════════════════════════════════════════════════════════ */

/* Footer "Powered by" on login */
.login .poweredby,
.login [class*="powered-by"],
.login .powered-by { display: none !important; }

/* Any Zammad wordmark rendered as text */
a[href="https://zammad.com"],
a[href*="zammad.com"]:not([class*="btn"]) {
  font-size: 0 !important;       /* hide text */
  pointer-events: none !important;
}

a[href="https://zammad.com"]::after,
a[href*="zammad.com"]:not([class*="btn"])::after {
  content: "National Finance IT Support";
  font-size: 12px !important;
  color: rgba(255,255,255,0.45) !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  16. TYPOGRAPHY                                            */
/* ══════════════════════════════════════════════════════════ */

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
  color: var(--nf-text) !important;
  -webkit-font-smoothing: antialiased !important;
}

h1, h2, h3, h4, h5, h6 {
  color: var(--nf-navy) !important;
  font-weight: 700 !important;
}


/* ══════════════════════════════════════════════════════════ */
/*  17. RESPONSIVE TWEAKS                                     */
/* ══════════════════════════════════════════════════════════ */

@media (max-width: 768px) {
  .login form,
  .login .login-form {
    padding: 24px !important;
    margin: 16px !important;
  }
}