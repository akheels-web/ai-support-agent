:root {
  --nf-navy: #1B2F6B;
  --nf-navy-dark: #132250;
  --nf-blue: #2B4A9F;
  --nf-light-blue: #E8EDF8;
  --nf-red: #C8102E;
  --nf-red-dark: #A50E26;
  --nf-bg: #F7F8FC;
  --nf-text: #2D2D2D;
  --nf-muted: #6B7280;
  --nf-border: #D1D9F0;
}

/* Global */
body {
  background: var(--nf-bg) !important;
  color: var(--nf-text) !important;
  font-family: "Inter", "Segoe UI", Arial, sans-serif !important;
}

/* Login page */
.login {
  background: linear-gradient(145deg, var(--nf-navy) 0%, var(--nf-blue) 70%) !important;
}

.login .login-form,
.login form,
.login .card {
  background: #ffffff !important;
  border-radius: 14px !important;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25) !important;
  border: none !important;
}

.login .logo,
.login-logo,
#logo {
  display: block !important;
  margin: 0 auto 24px auto !important;
  max-width: 220px !important;
  max-height: 80px !important;
}

.login label {
  color: var(--nf-navy) !important;
  font-weight: 700 !important;
  font-size: 12px !important;
  text-transform: uppercase !important;
}

.login input[type="text"],
.login input[type="email"],
.login input[type="password"] {
  border: 1.5px solid var(--nf-border) !important;
  border-radius: 8px !important;
  background: var(--nf-bg) !important;
  color: var(--nf-text) !important;
}

.login input:focus {
  border-color: var(--nf-blue) !important;
  box-shadow: 0 0 0 3px rgba(43, 74, 159, 0.15) !important;
  background: #ffffff !important;
}

.login button[type="submit"],
.login [type="submit"],
.login .btn-primary {
  background: var(--nf-navy) !important;
  border: none !important;
  border-radius: 8px !important;
  color: #ffffff !important;
  font-weight: 700 !important;
}

.login button[type="submit"]:hover,
.login [type="submit"]:hover,
.login .btn-primary:hover {
  background: var(--nf-blue) !important;
}

/* Hide powered by via CSS fallback */
.login .powered,
.login .poweredBy,
.login .poweredby,
.login .powered-by,
.login [class*="powered"] {
  display: none !important;
}

/* Custom footer */
.login::after {
  content: "© National Finance Oman · IT Support Portal";
  position: fixed;
  bottom: 18px;
  left: 0;
  right: 0;
  text-align: center;
  color: rgba(255, 255, 255, 0.65);
  font-size: 12px;
  pointer-events: none;
}

/* Top navigation */
#navigation,
.navigation,
nav.navigation,
.header,
.header-bar {
  background: var(--nf-navy) !important;
  border-bottom: 3px solid var(--nf-red) !important;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.20) !important;
}

#navigation a,
.navigation a,
.header a {
  color: rgba(255, 255, 255, 0.85) !important;
}

#navigation a:hover,
.navigation a:hover,
.header a:hover {
  color: #ffffff !important;
}

/* Sidebar */
.sidebar-left,
.column.left,
#app-content aside {
  background: var(--nf-light-blue) !important;
  border-right: 1px solid var(--nf-border) !important;
}

.sidebar-left a,
.column.left a {
  color: var(--nf-navy) !important;
  border-radius: 8px !important;
}

.sidebar-left a:hover,
.column.left a:hover {
  background: rgba(27, 47, 107, 0.10) !important;
}

.sidebar-left a.active,
.column.left a.active,
.sidebar-left .is-active {
  background: var(--nf-navy) !important;
  color: #ffffff !important;
  font-weight: 700 !important;
}

/* Cards and widgets */
.widget,
.stat-widget,
.dashboard .stats,
.card {
  background: #ffffff !important;
  border: 1px solid var(--nf-border) !important;
  border-radius: 12px !important;
  box-shadow: 0 2px 12px rgba(27, 47, 107, 0.10) !important;
}

.widget h2,
.stat-widget h2,
.widget .title,
.stat-widget .title {
  color: var(--nf-navy) !important;
  font-weight: 800 !important;
}

/* Tables */
.ticket-list,
.overview-table,
.js-tableBody {
  background: #ffffff !important;
  border: 1px solid var(--nf-border) !important;
  border-radius: 12px !important;
  overflow: hidden !important;
}

.ticket-list thead th,
.overview-table thead th,
.js-tableHead th {
  background: var(--nf-navy) !important;
  color: #ffffff !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
}

.ticket-list tbody tr:hover,
.overview-table tbody tr:hover,
.js-tableBody tr:hover {
  background: var(--nf-light-blue) !important;
}

/* Buttons */
.btn.btn-primary,
button.btn-primary,
.js-submit.btn-primary {
  background: var(--nf-navy) !important;
  border: none !important;
  border-radius: 8px !important;
  color: #ffffff !important;
  font-weight: 700 !important;
}

.btn.btn-primary:hover,
button.btn-primary:hover {
  background: var(--nf-blue) !important;
}

.btn.btn-danger,
button.btn-danger {
  background: var(--nf-red) !important;
  border: none !important;
  border-radius: 8px !important;
  color: #ffffff !important;
}

/* Ticket title and number */
.ticket-title h1,
.ticket-zoom-title,
h1.ticket-title {
  color: var(--nf-navy) !important;
  font-weight: 800 !important;
}

.ticket-number {
  color: var(--nf-red) !important;
  font-weight: 800 !important;
}

/* Forms */
input[type="text"],
input[type="email"],
input[type="search"],
textarea,
select {
  border: 1.5px solid var(--nf-border) !important;
  border-radius: 8px !important;
  color: var(--nf-text) !important;
}

input:focus,
textarea:focus,
select:focus {
  border-color: var(--nf-blue) !important;
  box-shadow: 0 0 0 3px rgba(43, 74, 159, 0.12) !important;
  outline: none !important;
}

/* Alerts */
.alert-success,
.notice.success {
  background: #D1FAE5 !important;
  border-left: 4px solid #10B981 !important;
  color: #065F46 !important;
}

.alert-warning,
.notice.warning {
  background: #FEF3C7 !important;
  border-left: 4px solid #F59E0B !important;
  color: #92400E !important;
}

.alert-danger,
.alert-error,
.notice.error {
  background: #FEE2E2 !important;
  border-left: 4px solid var(--nf-red) !important;
  color: var(--nf-red) !important;
}

.alert-info,
.notice.info {
  background: var(--nf-light-blue) !important;
  border-left: 4px solid var(--nf-navy) !important;
  color: var(--nf-navy) !important;
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
  color: var(--nf-navy) !important;
  font-weight: 800 !important;
}


